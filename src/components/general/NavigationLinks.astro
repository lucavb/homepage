---
interface Props {
    isHomePage?: boolean;
    variant?: 'desktop' | 'mobile';
    class?: string;
}

const { isHomePage = true, variant = 'desktop', class: className = '' } = Astro.props;

const baseClasses =
    variant === 'desktop'
        ? 'text-xs font-extrabold uppercase tracking-[0.11em] hover:underline decoration-2 underline-offset-4 transition-colors'
        : 'mobile-nav-link flex items-baseline gap-4 font-outfit text-4xl font-bold tracking-[-0.05em] text-[var(--paper)] hover:text-[var(--yellow)] transition-colors';

const containerClasses =
    variant === 'desktop'
        ? `hidden md:flex gap-7 ${className}`
        : `flex-1 flex flex-col justify-center gap-5 ${className}`;
---

{
    variant === 'desktop' ? (
        <nav class={containerClasses} aria-label="Main navigation">
            {isHomePage ? (
                <>
                    <a href="#focus" class={baseClasses}>
                        Focus
                    </a>
                    <a href="#experience" class={baseClasses}>
                        Experience
                    </a>
                    <a href="#work" class={baseClasses}>
                        Work
                    </a>
                    <a href="#writing" class={baseClasses}>
                        Writing
                    </a>
                    <a href="#contact" class={baseClasses}>
                        Contact
                    </a>
                </>
            ) : (
                <>
                    <a href="/" class={baseClasses}>
                        Home
                    </a>
                    <a href="/projects" class={baseClasses}>
                        Projects
                    </a>
                    <a href="/blog" class={baseClasses}>
                        Writing
                    </a>
                </>
            )}
        </nav>
    ) : (
        <nav class={containerClasses} aria-label="Main navigation">
            {isHomePage ? (
                <>
                    <a href="#focus" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">01</span> Focus
                    </a>
                    <a href="#experience" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">02</span> Experience
                    </a>
                    <a href="#work" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">03</span> Work
                    </a>
                    <a href="#writing" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">04</span> Writing
                    </a>
                    <a href="#contact" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">05</span> Contact
                    </a>
                </>
            ) : (
                <>
                    <a href="/" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">01</span> Home
                    </a>
                    <a href="/projects" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">02</span> Projects
                    </a>
                    <a href="/blog" class={baseClasses}>
                        <span class="eyebrow text-[var(--yellow)]">03</span> Writing
                    </a>
                </>
            )}
        </nav>
    )
}
