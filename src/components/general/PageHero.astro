---
interface Props {
    title: string;
    description?: string;
    eyebrow?: string;
    showBackLink?: boolean;
    backLinkText?: string;
    backLinkHref?: string;
    publishDate?: Date;
    tags?: string[];
}

const {
    title,
    description,
    eyebrow = 'Writing',
    showBackLink = false,
    backLinkText = 'Back to Writing',
    backLinkHref = '/blog',
    publishDate,
    tags = [],
} = Astro.props;

const formatDate = (date: Date) =>
    new Intl.DateTimeFormat('en-GB', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<section class="site-shell py-8 sm:py-12">
    <div class="bg-[var(--pale)] px-6 py-14 sm:px-12 sm:py-20 rounded-tr-[60px] sm:rounded-tr-[90px]">
        {
            showBackLink && (
                <a href={backLinkHref} class="eyebrow mb-10 inline-block hover:underline">
                    ← {backLinkText}
                </a>
            )
        }
        <p class="eyebrow mb-5">{eyebrow}</p>
        <h1 class="max-w-5xl text-5xl font-bold leading-[0.86] tracking-[-0.07em] sm:text-7xl lg:text-8xl">{title}</h1>
        {
            description && (
                <p class="mt-7 max-w-3xl text-lg leading-relaxed text-[var(--muted)] sm:text-xl">{description}</p>
            )
        }
        {
            (publishDate || tags.length > 0) && (
                <div class="mt-8 flex flex-wrap gap-x-3 gap-y-2 text-xs font-extrabold uppercase tracking-[0.1em]">
                    {publishDate && <time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>}
                    {publishDate && tags.length > 0 && <span aria-hidden="true">/</span>}
                    {tags.map((tag, index) => (
                        <>
                            <span>{tag}</span>
                            {index < tags.length - 1 && <span aria-hidden="true">/</span>}
                        </>
                    ))}
                </div>
            )
        }
    </div>
</section>
