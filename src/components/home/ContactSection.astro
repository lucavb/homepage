---
import { info } from '@data';
---

<section id="contact" class="site-shell pb-12 pt-8 sm:pb-16">
    <div
        class="grid min-h-[460px] gap-12 rounded-tl-[60px] bg-[var(--orange)] p-7 sm:grid-cols-[1.3fr_0.7fr] sm:p-12 lg:min-h-[530px] lg:rounded-tl-[90px]"
    >
        <div class="self-start">
            <h2 class="max-w-2xl text-6xl font-bold leading-[0.85] tracking-[-0.07em] sm:text-8xl">Let’s talk.</h2>
        </div>
        <div class="self-end">
            <p class="max-w-md text-lg leading-relaxed">
                Email me about consulting, talks, workshops, or software projects.
            </p>
            <span
                id="email-display"
                class="mt-6 block cursor-pointer text-xl font-extrabold underline decoration-2 underline-offset-4"
                title="Click to reveal email"
            >
                [Click to reveal email] ↗
            </span>
            <p class="eyebrow mt-10">Munich, Germany</p>
            <nav aria-label="Contact links" class="mt-4 flex flex-wrap gap-x-5 gap-y-3 text-sm font-extrabold">
                <a
                    href={info.socialMedia.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-2 underline-offset-4">GitHub</a
                >
                <a
                    href={info.socialMedia.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-2 underline-offset-4">LinkedIn</a
                >
                <a
                    href={info.socialMedia.matrix}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-2 underline-offset-4">Matrix</a
                >
            </nav>
        </div>
    </div>
</section>

<script>
    import { initEmailProtection } from '@utils';

    initEmailProtection([{ elementId: 'email-display', options: { autoReveal: true, isDisplayElement: true } }]);
</script>
