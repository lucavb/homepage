---
const chapters = [
    {
        period: '2023—now',
        title: 'TNG / Client platform',
        description: 'I lead five engineers, build backend services, and manage CI/CD and AWS infrastructure.',
    },
    {
        period: '2019—now',
        title: 'TNG / Consulting',
        description:
            'I build client software, teach AI-assisted coding, conduct technical interviews, and support technical due diligence.',
    },
    {
        period: '2016—2019',
        title: 'FZI / Research',
        description: 'I built IT-security prototypes for consumer hardware and an Android app for sensor telemetry.',
    },
];
---

<section id="experience" class="bg-[var(--ink)] py-20 text-[var(--paper)] sm:py-24">
    <div class="site-shell">
        <div class="mb-12 grid gap-6 sm:grid-cols-[72px_1fr] sm:items-start">
            <span class="index-circle bg-[var(--sky)] text-[var(--ink)]">02</span>
            <h2 class="max-w-4xl text-5xl font-bold leading-[0.88] tracking-[-0.07em] text-[var(--paper)] sm:text-7xl">
                Experience
            </h2>
        </div>
        <div class="grid border-t border-[color-mix(in_srgb,var(--paper)_35%,transparent)] md:grid-cols-3">
            {
                chapters.map((chapter, index) => (
                    <article
                        class:list={[
                            'py-7 md:px-7 md:py-8',
                            index > 0 &&
                                'border-t border-[color-mix(in_srgb,var(--paper)_35%,transparent)] md:border-l md:border-t-0',
                            index === 0 && 'md:pr-7',
                        ]}
                        data-animate
                    >
                        <time class="eyebrow text-[var(--yellow)]">{chapter.period}</time>
                        <h3 class="mt-5 text-3xl font-bold leading-[1.02] tracking-[-0.05em] text-[var(--paper)]">
                            {chapter.title}
                        </h3>
                        <p class="mt-5 leading-relaxed text-[color-mix(in_srgb,var(--paper)_75%,transparent)]">
                            {chapter.description}
                        </p>
                    </article>
                ))
            }
        </div>
    </div>
</section>
