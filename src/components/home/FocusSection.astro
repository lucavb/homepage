---
const focusAreas = [
    {
        symbol: 'AI',
        title: 'AI-assisted development',
        description:
            'I use coding agents such as Cursor and Claude Code in delivery work, and teach teams where they help and where they don’t.',
        color: 'bg-[var(--orange)]',
        corner: 'rounded-tl-[44px]',
    },
    {
        symbol: '{ }',
        title: 'Software engineering',
        description: 'I build and maintain backend and frontend systems in TypeScript and Java.',
        color: 'bg-[var(--pale)]',
        corner: 'rounded-none sm:rounded-tr-[44px]',
    },
    {
        symbol: '↑',
        title: 'Infrastructure',
        description: 'I manage AWS infrastructure and build CI/CD pipelines with GitHub Actions.',
        color: 'bg-[var(--yellow)]',
        corner: 'rounded-none sm:rounded-bl-[44px]',
    },
    {
        symbol: 'team',
        title: 'Team leadership',
        description: 'I lead engineers, teach new tools, and improve how the team works.',
        color: 'bg-[var(--green)]',
        corner: 'rounded-br-[44px]',
    },
];
---

<section id="focus" class="site-shell py-20 sm:py-24">
    <div class="mb-12 grid gap-6 sm:grid-cols-[72px_1fr] sm:items-start">
        <span class="index-circle">01</span>
        <h2 class="max-w-4xl text-5xl font-bold leading-[0.88] tracking-[-0.07em] sm:text-7xl">What I work on</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
        {
            focusAreas.map((area) => (
                <article
                    class={`flex min-h-72 flex-col justify-between p-6 sm:p-8 ${area.color} ${area.corner}`}
                    data-animate
                >
                    <span
                        class="grid size-16 place-items-center rounded-full border-2 border-current font-outfit text-xl font-bold"
                        aria-label={area.symbol === 'team' ? 'Team of five engineers' : undefined}
                    >
                        {area.symbol === 'team' ? (
                            <span class="grid grid-cols-3 gap-1.5" aria-hidden="true">
                                <span class="size-2.5 rounded-full bg-current" />
                                <span class="size-2.5 rounded-full bg-current" />
                                <span class="size-2.5 rounded-full bg-current" />
                                <span class="col-start-1 size-2.5 rounded-full bg-current" />
                                <span class="col-start-3 size-2.5 rounded-full bg-current" />
                            </span>
                        ) : (
                            area.symbol
                        )}
                    </span>
                    <div>
                        <h3 class="max-w-md text-3xl font-bold leading-none tracking-[-0.05em]">{area.title}</h3>
                        <p class="mt-4 max-w-xl leading-relaxed">{area.description}</p>
                    </div>
                </article>
            ))
        }
    </div>
</section>
