---
import { info } from '@data';
---

<section class="site-shell py-8 sm:py-12">
    <div class="grid gap-7 lg:min-h-[700px] lg:grid-cols-[1.2fr_0.8fr]">
        <div
            class="relative flex min-h-[420px] flex-col overflow-hidden rounded-tr-[60px] bg-[var(--sky)] p-7 sm:min-h-[620px] sm:p-12 lg:rounded-tr-[90px]"
        >
            <div
                class="absolute -bottom-24 -right-20 size-72 rounded-full border-[42px] border-white/25"
                aria-hidden="true"
            >
            </div>
            <p class="eyebrow relative z-10">{info.jobDescription}</p>
            <div class="relative z-10 mt-8">
                <h1 class="text-[clamp(3.4rem,7.7vw,8rem)] font-bold leading-[0.8] tracking-[-0.04em]">
                    I help teams get the most out of coding agents.
                </h1>
            </div>
            <div class="relative z-10 mt-12 max-w-xl lg:mt-auto">
                <p class="text-lg leading-relaxed sm:text-xl">{info.heroDescription}</p>
                <a
                    href="#focus"
                    class="mt-6 inline-block font-extrabold underline decoration-2 underline-offset-4"
                    data-umami-event="CTA Click"
                    data-umami-event-label="Get to know me"
                >
                    Get to know me ↓
                </a>
            </div>
        </div>

        <aside class="grid gap-7 sm:grid-cols-[0.9fr_1.1fr] lg:grid-cols-1 lg:grid-rows-[1.2fr_0.8fr]">
            <div
                class="min-h-[390px] overflow-hidden rounded-tr-[100px] rounded-bl-[100px] sm:h-full sm:min-h-0 lg:min-h-[390px]"
            >
                <picture>
                    <source
                        srcset="/assets/images/hero/400.avif 1x, /assets/images/hero/800.avif 2x"
                        type="image/avif"
                    />
                    <source
                        srcset="/assets/images/hero/400.webp 1x, /assets/images/hero/800.webp 2x"
                        type="image/webp"
                    />
                    <img
                        src="/assets/images/hero/400.jpg"
                        srcset="/assets/images/hero/400.jpg 1x, /assets/images/hero/800.jpg 2x"
                        alt={info.name}
                        class="h-full w-full object-cover object-top saturate-75"
                        width="400"
                        height="560"
                        loading="eager"
                        decoding="async"
                    />
                </picture>
            </div>
            <div class="grid grid-cols-2 bg-[var(--yellow)]">
                <div class="border-b border-r border-black/20 p-5">
                    <span class="eyebrow">Role</span><strong class="mt-2 block text-xl">Principal Consultant</strong>
                </div>
                <div class="border-b border-black/20 p-5">
                    <span class="eyebrow">Based in</span><strong class="mt-2 block text-xl">Munich</strong>
                </div>
                <div class="border-r border-black/20 p-5">
                    <span class="eyebrow">At TNG</span><strong class="mt-2 block text-xl">Since 2019</strong>
                </div>
                <div class="p-5">
                    <span class="eyebrow">Background</span><strong class="mt-2 block text-xl">IT security</strong>
                </div>
            </div>
        </aside>
    </div>
</section>
