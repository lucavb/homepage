---
import { Picture } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import Header from '@components/home/Header.astro';
import Footer from '@components/home/Footer.astro';
import PageHero from '@components/general/PageHero.astro';
import { projects } from '../data/projects';

const colors = [
    'bg-[var(--sky)]',
    'bg-[var(--yellow)]',
    'bg-[var(--green)]',
    'bg-[var(--orange)]',
    'bg-[var(--pale)]',
    'bg-[var(--yellow)]',
    'bg-[var(--sky)]',
    'bg-[var(--green)]',
    'bg-[var(--orange)]',
];

const cornerClasses = [
    'rounded-tl-[44px]',
    '',
    'rounded-tr-[44px]',
    '',
    '',
    '',
    'rounded-bl-[44px]',
    '',
    'rounded-br-[44px]',
];
---

<Layout
    title="Projects"
    description="Open-source tools, small utilities, and websites I’ve built."
    ogImageUrl="/assets/images/og-image.png"
>
    <Header isHomePage={false} />
    <main id="main-content">
        <PageHero
            eyebrow="Work"
            title="Projects"
            description="Open-source tools, small utilities, and websites I’ve built."
        />
        <section class="site-shell py-16 sm:py-24">
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {
                    projects.map((project, index) => {
                        const primaryUrl = project.liveUrl ?? project.githubUrl ?? '#';
                        return (
                            <article
                                class={`group relative isolate flex min-h-[360px] overflow-hidden p-7 ${colors[index]} ${cornerClasses[index]}`}
                                data-animate
                            >
                                <Picture
                                    src={project.thumbnail}
                                    alt=""
                                    formats={['avif', 'webp']}
                                    widths={[500, 700]}
                                    width={700}
                                    height={500}
                                    loading="lazy"
                                    class="pointer-events-none absolute inset-0 -z-10 size-full object-cover opacity-15 grayscale transition-opacity duration-200 group-hover:opacity-30 group-focus-within:opacity-30"
                                />
                                <div class="flex w-full flex-col justify-between">
                                    <div>
                                        <span class="eyebrow">{project.category}</span>
                                        <h2 class="mt-8 text-4xl font-bold leading-[0.9] tracking-[-0.06em]">
                                            <a
                                                href={primaryUrl}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="after:absolute after:inset-0 after:z-0 hover:underline"
                                            >
                                                {project.title}
                                            </a>
                                        </h2>
                                        <p class="relative z-10 mt-5 leading-relaxed">{project.summary}</p>
                                    </div>
                                    <div class="relative z-10 mt-8 flex items-end justify-between gap-4">
                                        <span class="max-w-[80%] text-xs font-extrabold uppercase tracking-[0.08em]">
                                            {project.technologies.join(' / ')}
                                        </span>
                                        <span class="shrink-0 text-5xl transition-transform duration-200 group-hover:translate-x-1 group-focus-within:translate-x-1">
                                            ↗
                                        </span>
                                    </div>
                                    {project.githubUrl && project.githubUrl !== primaryUrl && (
                                        <a
                                            href={project.githubUrl}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="relative z-10 mt-5 w-max text-sm font-extrabold underline decoration-2 underline-offset-4"
                                        >
                                            GitHub →
                                        </a>
                                    )}
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </section>
    </main>
    <Footer />
</Layout>
