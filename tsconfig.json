{
    "compilerOptions": {
        // Enable top-level await, and other modern ESM features.
        "target": "ESNext",
        "module": "ESNext",
        // Use bundler module resolution for modern ESM subpath exports (e.g. astro/loaders, astro/zod).
        "moduleResolution": "bundler",
        // Enable JSON imports.
        "resolveJsonModule": true,
        // Enable stricter transpilation for better output.
        "isolatedModules": true,
        // Astro will directly run your TypeScript code, no transpilation needed.
        "noEmit": true,
        "strict": true,
        // TS 6+: explicit @types for globals (playwright.config.ts, etc.); avoid enumerating all of node_modules/@types.
        "types": ["node"],
        "paths": {
            "@layouts/*": ["./src/layouts/*"],
            "@components/*": ["./src/components/*"],
            "@data": ["./src/data/info"],
            "@utils": ["./src/utils"],
            "@types": ["./src/types"]
        }
    }
}
